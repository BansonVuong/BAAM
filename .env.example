# ── Relayer / Solana ──────────────────────────────────────────────────────────
# Oracle keypair (also the tx payer). Must match commitments' oracle_pubkey.
ORACLE_KEYPAIR=~/.config/solana/id.json
SOLANA_RPC_URL=https://api.devnet.solana.com
HOST=127.0.0.1
PORT=8787
POLL_INTERVAL_MS=60000

# Required outside local development. Generate a long random value and never
# commit it; changing it invalidates existing login sessions.
AUTH_SECRET=

# ── Custodial wallets + on-chain SOL bets ─────────────────────────────────────
# Each user gets a relayer-managed devnet keypair; the relayer signs create/accept
# on their behalf and the oracle settles the bet. All bets escrow real lamports.
# Witness bets escrow BOTH stakes atomically when accepted, so a posted bet waits
# indefinitely for a taker. Sports bets escrow the challenger at post time and must
# be accepted before kickoff.
#
# Encryption key for stored wallet secrets. Required outside local development;
# falls back to a key derived from AUTH_SECRET (with a warning) when unset.
WALLET_SECRET_KEY=
# Devnet airdrop granted to each new custodial wallet (lamports; default 2 SOL).
WALLET_AIRDROP_LAMPORTS=2000000000
# Sports bets: accept window before kickoff (seconds; default 120).
SOCIAL_BET_WINDOW_SECS=120
# Witness bets: delay after acceptance before the bet can settle (seconds; default
# 15). Only needs to span the single atomic create+accept transaction.
SOCIAL_BET_SETTLE_DELAY_SECS=15

# ── MongoDB (optional) ────────────────────────────────────────────────────────
# Leave MONGODB_URI unset and the relayer runs without a database — the dashboard
# falls back to its built-in design fixtures. Set it (e.g. an Atlas connection
# string with your username/password) and the relayer connects on first request,
# auto-seeds the collections, and serves real data from:
#   GET/POST /groups   GET /messages?group=1   POST /messages
#   GET /bets   GET /leaderboard   GET/POST /profiles   GET/PATCH /profiles/:id
#
# Atlas: Database → Connect → Drivers → copy the connection string and drop your
# password in. The credentials ("API keys") live entirely inside this URI.
MONGODB_URI=
MONGODB_DB=accountabilibuddy
MONGODB_TIMEOUT_MS=5000
